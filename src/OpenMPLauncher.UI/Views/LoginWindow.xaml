<Window x:Class="OpenMPLauncher.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenMP Launcher - Вход"
        Height="600" Width="900"
        Background="#0F0F0F"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True">
    
    <Grid>
        <!-- Background gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F0F0F" Offset="0"/>
                <GradientStop Color="#1A0033" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Main container -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Left side - Banner -->
            <Border Grid.Column="0" Background="#1A1A2E" Margin="10,10,0,10" CornerRadius="15,0,0,15">
                <Image Source="/Resources/banner.png" Stretch="UniformToFill"/>
            </Border>

            <!-- Right side - Login form -->
            <Border Grid.Column="1" 
                    Background="#1A1A2E"
                    BorderBrush="#9D4EDD"
                    BorderThickness="1,1,1,1"
                    CornerRadius="0,15,15,0"
                    Margin="0,10,10,10"
                    Padding="30">
                
                <StackPanel VerticalAlignment="Center" Spacing="20">
                    <!-- Logo/Title -->
                    <TextBlock Text="OpenMP"
                               Foreground="#9D4EDD"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="LAUNCHER"
                               Foreground="#FFFFFF"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               Margin="0,-10,0,10"/>

                    <!-- Username field -->
                    <TextBlock Text="НИКНЕЙМ"
                               Foreground="#9D4EDD"
                               FontSize="12"
                               FontWeight="Bold"/>
                    <TextBox x:Name="UsernameTextBox"
                             Height="45"
                             Background="#0F0F0F"
                             Foreground="#FFFFFF"
                             BorderBrush="#9D4EDD"
                             BorderThickness="1"
                             CornerRadius="5"
                             Padding="15,0"
                             FontSize="14"
                             Text=""/>

                    <!-- Password field -->
                    <TextBlock Text="ПАРОЛЬ"
                               Foreground="#9D4EDD"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0,10,0,0"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Height="45"
                                 Background="#0F0F0F"
                                 Foreground="#FFFFFF"
                                 BorderBrush="#9D4EDD"
                                 BorderThickness="1"
                                 CornerRadius="5"
                                 Padding="15,0"
                                 FontSize="14"/>

                    <!-- Remember me -->
                    <CheckBox Content="Запомнить меня"
                              Foreground="#9D4EDD"
                              IsChecked="True"
                              Background="Transparent"/>

                    <!-- Login button -->
                    <Button Content="ВОЙТИ"
                            Height="50"
                            Background="#9D4EDD"
                            Foreground="#FFFFFF"
                            FontSize="14"
                            FontWeight="Bold"
                            CornerRadius="5"
                            Cursor="Hand"
                            Margin="0,10,0,0">
                        <Button.Effect>
                            <DropShadowEffect Color="#9D4EDD" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                        </Button.Effect>
                    </Button>

                    <!-- Divider -->
                    <Grid Height="1" Margin="0,10">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#9D4EDD" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                    </Grid>

                    <!-- Register button -->
                    <Button Content="СОЗДАТЬ АККАУНТ"
                            Height="50"
                            Background="Transparent"
                            Foreground="#9D4EDD"
                            BorderBrush="#9D4EDD"
                            BorderThickness="1"
                            FontSize="14"
                            FontWeight="Bold"
                            CornerRadius="5"
                            Cursor="Hand"/>

                    <!-- Links -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0" Spacing="10">
                        <Button Content="Забыли пароль?"
                                Background="Transparent"
                                Foreground="#9D4EDD"
                                FontSize="12"/>
                        <TextBlock Text="|" Foreground="#9D4EDD"/>
                        <Button Content="Помощь"
                                Background="Transparent"
                                Foreground="#9D4EDD"
                                FontSize="12"/>
                    </StackPanel>

                    <!-- Close button -->
                    <Button Content="✕ Выход"
                            Height="40"
                            Background="Transparent"
                            Foreground="#FF6B6B"
                            BorderBrush="#FF6B6B"
                            BorderThickness="1"
                            FontSize="12"
                            FontWeight="Bold"
                            CornerRadius="5"
                            Cursor="Hand"
                            Margin="0,20,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Close button (top right) -->
        <Button Width="40" Height="40" 
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                Foreground="#FF6B6B"
                FontSize="18"
                Content="✕"
                Margin="10"
                Cursor="Hand"/>
    </Grid>
</Window>
